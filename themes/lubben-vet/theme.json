{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "useRootPaddingAwareAlignments": true,
    "appearanceTools": false,
    "color": {
      "custom": true,
      "customDuotone": false,
      "defaultPalette": false,
      "palette": [
        { "slug": "bg", "color": "#F3F3F4", "name": "Background" },
        { "slug": "surface", "color": "#FFFFFF", "name": "Surface" },
        { "slug": "text", "color": "#58595B", "name": "Text" },
        { "slug": "text-muted", "color": "#808285", "name": "Muted text" },
        { "slug": "primary", "color": "#292A76", "name": "Primary" },
        { "slug": "primary-hover", "color": "#1E1F58", "name": "Primary hover" },
        { "slug": "accent", "color": "#B87333", "name": "Accent" },
        { "slug": "border", "color": "#D7D8DA", "name": "Border" },
        { "slug": "focus", "color": "#292A76", "name": "Focus" }
      ]
    },
    "typography": {
      "customFontSize": true,
      "fontFamilies": [
        {
          "fontFamily": "\"TT Norms Pro Serif\", Georgia, \"Times New Roman\", serif",
          "slug": "tt-norms-pro-serif",
          "name": "TT Norms Pro Serif",
          "fontFace": [
            {
              "fontFamily": "TT Norms Pro Serif",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/tt-norms-pro-serif-400.woff2" ]
            },
            {
              "fontFamily": "TT Norms Pro Serif",
              "fontWeight": "400",
              "fontStyle": "italic",
              "src": [ "file:./assets/fonts/tt-norms-pro-serif-400-italic.woff2" ]
            },
            {
              "fontFamily": "TT Norms Pro Serif",
              "fontWeight": "500",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/tt-norms-pro-serif-500.woff2" ]
            },
            {
              "fontFamily": "TT Norms Pro Serif",
              "fontWeight": "600",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/tt-norms-pro-serif-500.woff2" ]
            },
            {
              "fontFamily": "TT Norms Pro Serif",
              "fontWeight": "700",
              "fontStyle": "normal",
              "src": [ "file:./assets/fonts/tt-norms-pro-serif-700.woff2" ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "body", "size": "clamp(1rem, 0.95rem + 0.25vw, 1.0625rem)", "name": "Body" },
        { "slug": "h3", "size": "clamp(1.25rem, 1.15rem + 0.5vw, 1.5rem)", "name": "Heading 3" },
        { "slug": "h2", "size": "clamp(1.5rem, 1.3rem + 0.9vw, 2rem)", "name": "Heading 2" },
        { "slug": "h1", "size": "clamp(1.875rem, 1.55rem + 1.4vw, 2.5rem)", "name": "Heading 1" },
        { "slug": "display", "size": "clamp(2.25rem, 1.85rem + 2vw, 3.5rem)", "name": "Display" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "1", "size": "0.25rem", "name": "4px" },
        { "slug": "2", "size": "0.5rem", "name": "8px" },
        { "slug": "3", "size": "0.75rem", "name": "12px" },
        { "slug": "4", "size": "1rem", "name": "16px" },
        { "slug": "5", "size": "1.5rem", "name": "24px" },
        { "slug": "6", "size": "2rem", "name": "32px" },
        { "slug": "7", "size": "3rem", "name": "48px" },
        { "slug": "8", "size": "4rem", "name": "64px" },
        { "slug": "9", "size": "6rem", "name": "96px" }
      ]
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1140px"
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--tt-norms-pro-serif)",
      "fontSize": "var(--wp--preset--font-size--body)",
      "lineHeight": "1.6"
    },
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--tt-norms-pro-serif)",
          "fontSize": "var(--wp--preset--font-size--h1)",
          "lineHeight": "1.2",
          "fontWeight": "700"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--tt-norms-pro-serif)",
          "fontSize": "var(--wp--preset--font-size--h2)",
          "lineHeight": "1.2",
          "fontWeight": "700"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--tt-norms-pro-serif)",
          "fontSize": "var(--wp--preset--font-size--h3)",
          "lineHeight": "1.2",
          "fontWeight": "500"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        "typography": { "textDecoration": "underline" }
      }
    }
  },
  "patterns": [ "hero-banner", "staff-card", "cta-pharmacy" ]
}
